# Copia este archivo a .env y configura tu URI de MongoDB Atlas.
MONGODB_URI=mongodb+srv://<usuario>:<contraseña>@cluster0.lbofv9e.mongodb.net/agromin?retryWrites=true&w=majority

# Si tu red bloquea las consultas SRV, usa una URI directa con los hosts de tu clúster.
# Para Atlas, reemplaza <usuario> y <contraseña> y ajusta los hosts y parámetros.
# MONGO_DIRECT_URI=mongodb://<usuario>:<contraseña>@ac-fsalayu-shard-00-00.lbofv9e.mongodb.net:27017,ac-fsalayu-shard-00-01.lbofv9e.mongodb.net:27017,ac-fsalayu-shard-00-02.lbofv9e.mongodb.net:27017/agromin?authSource=admin&replicaSet=atlas-7q8zdh-shard-0&tls=true&retryWrites=true&w=majority
DB_NAME=agromin
COLLECTION_NAME=states
PORT=3000
